---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';
import { getCollection } from 'astro:content';

// 最新記事を取得
const posts = (await getCollection('blog'))
  .sort((a, b) => new Date(b.data.pubDate) - new Date(a.data.pubDate))
  .slice(0, 6);
---

<!doctype html>
<html lang="ja">
  <head>
    <BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
  </head>

  <body>
    <Header />

    <main class="container" style="max-width: 900px; margin: 0 auto; padding: 2rem;">
      <!-- タイトル -->
      <section style="text-align: center; margin-bottom: 3rem;">
        <h1 style="font-size: 2.4rem; margin-bottom: 0.5rem;">もそもそ歴史ブログ</h1>
        <p style="color: #666; font-size: 1.1rem;">
          歴史・IT・資格学習など、気ままに記録していくブログです。
        </p>
      </section>

      <!-- 最新記事一覧 -->
      <section>
        <h2 style="font-size: 1.6rem; margin-bottom: 1rem;">最新の記事</h2>

        <div style="
          display: grid;
          grid-template-columns: repeat(auto-fit, minmax(260px, 1fr));
          gap: 1.5rem;
        ">
          {posts.map(post => (
            <a
              href={`blog/${post.slug}/`}
              style="
                display: block;
                padding: 1rem;
                border: 1px solid #ddd;
                border-radius: 8px;
                text-decoration: none;
                color: inherit;
                background: #fff;
                transition: box-shadow 0.2s;
              "
            >
              <h3 style="margin: 0 0 0.5rem 0; font-size: 1.2rem;">
                {post.data.title}
              </h3>
              <p style="margin: 0; color: #666; font-size: 0.9rem;">
                {new Date(post.data.pubDate).toLocaleDateString('ja-JP')}
              </p>
            </a>
          ))}
        </div>
      </section>

      <!-- カテゴリリンク -->
      <section style="margin-top: 3rem;">
        <h2 style="font-size: 1.6rem; margin-bottom: 1rem;">カテゴリ</h2>
        <ul style="display: flex; gap: 1rem; flex-wrap: wrap; padding-left: 0;">
          <li><a href="blog/it/" style="text-decoration: none;">IT</a></li>
          <li><a href="blog/history/" style="text-decoration: none;">歴史</a></li>
          <li><a href="blog/資格/" style="text-decoration: none;">資格</a></li>
        </ul>
      </section>
    </main>

    <Footer />
  </body>
</html>
